# Telegram bot token from @BotFather (required for the bot; API works without it)
TELEGRAM_BOT_TOKEN=

# Linkup API key from https://app.linkup.so for live place data with ratings
# and reviews (optional; falls back to SerpAPI, then to a Goa seed list)
LINKUP_API_KEY=

# Destination used when the user's message doesn't name one
DEFAULT_DESTINATION=Goa, India

# SerpAPI key from https://serpapi.com - used only for fetching a real photo
# per place (Google Maps thumbnails) and as a place-data fallback
SERPAPI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Public base URL used to build trip links sent to Telegram
# (ngrok/cloudflared tunnel or http://<server-ip>:8000)
PUBLIC_BASE_URL=https://www.rahuljoshi.info

# Portrait video by default (phone/reel friendly). Use 1280x720 for landscape.
VIDEO_WIDTH=720
VIDEO_HEIGHT=1280

# Optional background music file mixed low under the narration
MUSIC_PATH=

# Hours a generated video stays available at its public link
TRIP_TTL_HOURS=1

# Hermes-native skill preloaded into every planning call (see
# skills/trip-planner/SKILL.md; install into ~/.hermes/skills/travel/).
# Set empty to disable and fall back to prompt-only behaviour.
HERMES_SKILL=trip-planner
# Toolset enabled per hermes -z call (keeps the skill mechanism active)
HERMES_TOOLSETS=skills
